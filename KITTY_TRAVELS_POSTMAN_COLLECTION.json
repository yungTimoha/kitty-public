{
  "info": {
    "name": "Kittygram API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Полное API Kittygram: котики, лайки, избранное, кото-путешествия и проверка прав."
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8001"
    },
    {
      "key": "demo_username",
      "value": "demo"
    },
    {
      "key": "demo_password",
      "value": "Demo1234!"
    },
    {
      "key": "viewer_username",
      "value": "viewer"
    },
    {
      "key": "viewer_password",
      "value": "Viewer1234!"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "viewer_token",
      "value": ""
    },
    {
      "key": "cat_id",
      "value": "1"
    },
    {
      "key": "other_cat_id",
      "value": "3"
    },
    {
      "key": "travel_id",
      "value": "1"
    },
    {
      "key": "other_travel_id",
      "value": "2"
    },
    {
      "key": "stop_id",
      "value": "1"
    },
    {
      "key": "checklist_item_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "01. Auth: получить JWT для demo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/jwt/create/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "jwt",
            "create"
          ]
        },
        "description": "Получает JWT access токен для demo. Токен сохраняется в access_token.",
        "auth": {
          "type": "noauth"
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{demo_username}}\",\n  \"password\": \"{{demo_password}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('access_token', json.access);"
            ]
          }
        }
      ]
    },
