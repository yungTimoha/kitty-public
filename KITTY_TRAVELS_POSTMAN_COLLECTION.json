      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Task is done', function () {",
              "  pm.expect(pm.response.json().is_done).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"is_done\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/travel-checklist/{{checklist_item_id}}/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "travel-checklist",
            "{{checklist_item_id}}"
          ]
