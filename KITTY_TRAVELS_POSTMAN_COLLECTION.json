      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cat\": {{cat_id}},\n  \"title\": \"Летняя поездка\",\n  \"destination\": \"Казань\",\n  \"start_date\": \"2026-06-01\",\n  \"end_date\": \"2026-06-05\",\n  \"transport\": \"поезд\",\n  \"status\": \"planned\",\n  \"is_public\": true,\n  \"notes\": \"Взять переноску и любимый плед.\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/travels/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "travels"
          ]
        },
        "description": "Создает путешествие для котика текущего пользователя."
      }
    },
    {
