          "raw": "{{base_url}}/travels/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "travels"
          ]
        },
        "description": "Возвращает свои и публичные путешествия."
      }
    },
    {
      "name": "05. Получить мои путешествия",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/travels/my/",
          "host": [
            "{{base_url}}"
