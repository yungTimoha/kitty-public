{
  "info": {
    "_postman_id": "6db3b8f5-3e06-4dfb-8c8a-9d33b7d0b001",
    "name": "Kittygram - Кото-путешествия",
    "description": "Проверочные запросы для сценария \"Кото-путешествия\". Коллекция использует переменные base_url, access_token, cat_id, travel_id, stop_id и checklist_item_id.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "username",
      "value": "tester"
    },
    {
      "key": "password",
      "value": "testpass123"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "cat_id",
      "value": "1"
    },
    {
      "key": "travel_id",
      "value": "1"
    },
    {
      "key": "stop_id",
      "value": "1"
    },
    {
      "key": "checklist_item_id",
      "value": "1"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01. Получить JWT-токен",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('access_token', json.access);"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/jwt/create/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "jwt",
            "create"
          ]
        },
        "description": "Получает JWT access token для последующих защищенных запросов."
      }
    },
    {
      "name": "02. Создать котика для путешествия",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('cat_id', json.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Marta\",\n  \"color\": \"Ginger\",\n  \"birth_year\": 2022\n}"
        },
        "url": {
          "raw": "{{base_url}}/cats/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "cats"
          ]
        },
        "description": "Создает котика, для которого будет планироваться путешествие."
      }
    },
    {
      "name": "03. Создать путешествие",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
